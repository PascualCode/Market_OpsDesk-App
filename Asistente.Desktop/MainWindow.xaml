                            <Button x:Name="TaskSelectNewAttachmentsButton"
                                    Grid.Column="2"
                                    Content="Adjuntar"
                                    Style="{StaticResource PosterGreenHoverButtonStyle}"
                                    Margin="8,0,8,0"
                                    Click="TaskSelectNewAttachmentsButton_Click"/>

                            <Button x:Name="TaskClearNewAttachmentsButton"
                                    Grid.Column="3"
                                    Content="Limpiar"
                                    Style="{StaticResource PosterGreenHoverButtonStyle}"
                                    Click="TaskClearNewAttachmentsButton_Click"/>
                        </Grid>

                        <Grid Grid.Row="6"
                              Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="TasksStatusText"
                                       Grid.Column="0"
                                       Text="Listo."
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>

                            <Button x:Name="TaskAddButton"
                                    Grid.Column="1"
                                    Content="Añadir"
                                    Style="{StaticResource PosterGreenHoverButtonStyle}"
                                    Click="TaskAddButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Separador -->
                <TextBlock Grid.Row="2"
                           Text="Tareas / recordatorios creados"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Margin="0,0,0,8"/>

                <!-- Mitad inferior: listado -->
                <Border Grid.Row="3"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="12"
                        Margin="0,0,0,12">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Filtros visuales -->
                        <Grid Grid.Row="0"
                              Margin="0,0,0,10">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Fila 1: filtros actuales -->
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Grupo:"
                                       FontSize="12"
                                       Foreground="#374151"
                                       VerticalAlignment="Center"/>

                            <ComboBox x:Name="TaskFilterGroupComboBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Height="30"
                                      Margin="0,0,10,0"
                                      SelectionChanged="TaskFilters_SelectionChanged"/>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       Text="Urgencia:"
                                       FontSize="12"
                                       Foreground="#374151"
                                       VerticalAlignment="Center"/>

                            <ComboBox x:Name="TaskFilterPriorityComboBox"
                                      Grid.Row="0"
                                      Grid.Column="3"
                                      Height="30"
                                      Margin="0,0,10,0"
                                      SelectedIndex="0"
                                      SelectionChanged="TaskFilters_SelectionChanged">
                                <ComboBoxItem Content="Todas"/>
                                <ComboBoxItem Content="Muy urgente"/>
                                <ComboBoxItem Content="Urgente"/>
                                <ComboBoxItem Content="Normal"/>
                            </ComboBox>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="4"
                                       Text="Estado:"
                                       FontSize="12"
                                       Foreground="#374151"
                                       VerticalAlignment="Center"/>

                            <ComboBox x:Name="TaskFilterStatusComboBox"
                                      Grid.Row="0"
                                      Grid.Column="5"
                                      Height="30"
                                      SelectedIndex="0"
                                      SelectionChanged="TaskFilters_SelectionChanged">
                                <ComboBoxItem Content="Todos"/>
                                <ComboBoxItem Content="En plazo"/>
                                <ComboBoxItem Content="Fuera de plazo"/>
                            </ComboBox>

                            <!-- Fila 2: búsqueda por dirigido a -->
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Dirigido a:"
                                       FontSize="12"
                                       Foreground="#374151"
                                       VerticalAlignment="Center"
                                       Margin="0,8,0,0"/>

                            <TextBox x:Name="TaskFilterAssignedToTextBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="5"
                                     Height="30"
                                     Margin="0,8,0,0"
                                     VerticalContentAlignment="Center"
                                     TextChanged="TaskFilterAssignedToTextBox_TextChanged"/>
                        </Grid>

                        <!-- Lista de tareas -->
                        <ListBox x:Name="TasksListBox"
                                 Grid.Row="1"
                                 SelectionMode="Extended"
                                 MouseDoubleClick="TasksListBox_MouseDoubleClick"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" Cursor="">

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>

                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            Padding="10"
                                            Margin="0,0,0,8"
                                            BorderThickness="2"
                                            BorderBrush="#111827">

                                        <Border.Style>
                                            <Style TargetType="Border">

                                                <!-- Normal en plazo: azul más intenso -->
                                                <Setter Property="Background" Value="#60A5FA"/>
                                                <Setter Property="BorderBrush" Value="#111827"/>
                                                <Setter Property="BorderThickness" Value="2"/>

                                                <Style.Triggers>

                                                    <!-- Urgente en plazo: naranja más intenso -->
                                                    <DataTrigger Binding="{Binding Priority}" Value="Urgente">
                                                        <Setter Property="Background" Value="#FB923C"/>
                                                    </DataTrigger>

                                                    <!-- Muy urgente en plazo: rojo intenso -->
                                                    <DataTrigger Binding="{Binding Priority}" Value="MuyUrgente">
                                                        <Setter Property="Background" Value="#EF4444"/>
                                                    </DataTrigger>

                                                    <!-- Fuera de plazo domina sobre cualquier prioridad -->
                                                    <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                        <Setter Property="Background" Value="Black"/>
                                                        <Setter Property="BorderBrush" Value="Gray"/>
                                                        <Setter Property="BorderThickness" Value="3"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Línea principal -->
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="{Binding DisplayText, Mode=OneWay}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="1"
                                                       Text="{Binding StatusText, Mode=OneWay}"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       Margin="12,0,0,0"/>

                                            <!-- Información secundaria -->
                                            <StackPanel Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        Orientation="Vertical"
                                                        Margin="0,4,0,0">

                                                <TextBlock Text="{Binding WrittenBy, StringFormat=Escrito por: {0}, Mode=OneWay}"
                                                           FontSize="11"
                                                           Foreground="White"/>

                                                <TextBlock FontSize="11"
                                                           Foreground="White">
                                                    <Run Text="Grupo: "/>
                                                    <Run Text="{Binding GroupDisplayName, Mode=OneWay}"/>
                                                    <Run Text=" · Urgencia: "/>
                                                    <Run Text="{Binding PriorityDisplayText, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding AttachmentCountText, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Botones inferiores -->
                <Grid Grid.Row="4">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Azul: normal · Naranja: urgente · Rojo: muy urgente · Negro: fuera de plazo"
                               Grid.Column="0"
                               FontSize="11"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"/>

                    <Button x:Name="TaskShowButton"
                            Grid.Column="1"
                            Content="Mostrar"
                            Style="{StaticResource PosterGreenHoverButtonStyle}"
                            Margin="0,0,8,0"
                            Click="TaskShowButton_Click"/>

                    <Button x:Name="TaskDeleteButton"
                            Grid.Column="2"
                            Content="Quitar"
                            Style="{StaticResource PosterGreenHoverButtonStyle}"
                            Click="TaskDeleteButton_Click" Cursor="Hand"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Panel emergente de detalle de tarea -->
        <Border x:Name="TaskDetailPanel"
                Width="460"
                Height="360"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,250,310"
                Background="#FFFFFFFF"
                CornerRadius="22"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                Padding="18"
                Visibility="Collapsed"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5" Grid.ColumnSpan="2">

            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="6"
                                  Opacity="0.25"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,12">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Detalle de tarea"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#111827"
                               VerticalAlignment="Center"/>

                    <Button x:Name="TaskDetailCloseButton"
                            Grid.Column="1"
                            Width="28"
                            Height="28"
                            Content="X"
                            FontWeight="Bold"
                            Foreground="White"
                            Background="#DC2626"
                            BorderBrush="#991B1B"
                            BorderThickness="1"
                            Click="TaskDetailCloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="14">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <TextBlock Text="Escrito por"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>
                        <TextBlock x:Name="TaskDetailWrittenByText"
                                   Margin="0,2,0,10"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Dirigido a"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>
                        <TextBlock x:Name="TaskDetailAssignedToText"
                                   Margin="0,2,0,10"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Fecha emisión"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>
                        <TextBlock x:Name="TaskDetailCreatedAtText"
                                   Margin="0,2,0,10"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Fecha vencimiento"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>
                        <TextBlock x:Name="TaskDetailDueAtText"
                                   Margin="0,2,0,10"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Nueva fecha límite"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>

                        <Grid Margin="0,2,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <DatePicker x:Name="TaskDetailNewDueDatePicker"
                                        Grid.Column="0"
                                        Height="32"
                                        Margin="0,0,8,0"/>

                            <Button x:Name="TaskPostponeButton"
                                    Grid.Column="1"
                                    Content="Aplazar fecha"
                                    Style="{StaticResource PosterGreenHoverButtonStyle}"
                                    Click="TaskPostponeButton_Click"/>
                        </Grid>
                        <TextBlock Text="Grupo"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>
                        <TextBlock x:Name="TaskDetailGroupText"
                                   Margin="0,2,0,10"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Urgencia"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>
                        <TextBlock x:Name="TaskDetailPriorityText"
                                   Margin="0,2,0,10"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Descripción"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>

                        <TextBlock x:Name="TaskDetailDescriptionText"
                                   Margin="0,2,0,8"
                                   TextWrapping="Wrap"/>

                        <TextBox x:Name="TaskDetailDescriptionEditTextBox"
                                 Margin="0,2,0,8"
                                 MinHeight="90"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Visibility="Collapsed"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="TaskEditDescriptionButton"
                                    Grid.Column="1"
                                    Content="Editar descripción"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    Click="TaskEditDescriptionButton_Click"/>

                            <Button x:Name="TaskSaveDescriptionButton"
                                    Grid.Column="2"
                                    Content="Guardar"
                                    Style="{StaticResource PosterGreenHoverButtonStyle}"
                                    Margin="0,0,8,0"
                                    Visibility="Collapsed"
                                    Click="TaskSaveDescriptionButton_Click"/>

                            <Button x:Name="TaskCancelDescriptionEditButton"
                                    Grid.Column="3"
                                    Content="Cancelar"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Visibility="Collapsed"
                                    Click="TaskCancelDescriptionEditButton_Click"/>
                        </Grid>
                        <TextBlock Text="Archivos adjuntos"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Margin="0,8,0,0"/>

                        <ListBox x:Name="TaskAttachmentsListBox"
                                 Height="90"
                                 Margin="0,4,0,8"
                                 DisplayMemberPath="DisplayText"
                                 SelectionMode="Single"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="TaskUploadAttachmentButton"
                                    Grid.Column="1"
                                    Content="Adjuntar archivo"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    Click="TaskUploadAttachmentButton_Click"/>

                            <Button x:Name="TaskDownloadAttachmentButton"
                                    Grid.Column="2"
                                    Content="Descargar"
                                    Style="{StaticResource PosterGreenHoverButtonStyle}"
                                    Click="TaskDownloadAttachmentButton_Click"/>
                            <Button x:Name="TaskDeleteAttachmentButton"
                                    Grid.Column="3"
                                    Content="Eliminar"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0"
                                    Click="TaskDeleteAttachmentButton_Click"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>



        <!-- BOTONES -->
        <!--
            Cuanto mayor sea el tercer número, más a la izquierda se mueve.
            Cuanto mayor sea el cuarto número, más arriba se mueve.
        -->
        <!-- Botón flotante superior para el generador de carteles -->
        <Button x:Name="PosterToggleButton"
        Content="🏷"
        Style="{StaticResource FloatingCircleButtonStyle}"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="0,0,135,95"
        ToolTip="Generador de carteles"
        Click="PosterToggleButton_Click" Cursor="" Grid.Column="1"/>

        <!-- Botón flotante inferior para impresión rápida -->
        <Button x:Name="QuickPrintToggleButton"
        Content="🖨"
        Style="{StaticResource FloatingCircleButtonStyle}"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="0,0,148,30"
        ToolTip="Impresión rápida"
        Click="QuickPrintToggleButton_Click" Grid.Column="1"/>


        <!-- Botón flotante para tareas y recordatorios -->
        <Button x:Name="FloatingTasksButton"
        Width="55"
        Height="52"
        Content="📅"
        FontSize="20"
        FontWeight="Bold"
        Foreground="White"
        Background="#2563EB"
        BorderBrush="#1D4ED8"
        BorderThickness="1"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="0,0,80,142"
        Cursor="Hand"
        ToolTip="Tareas y recordatorios"
        Click="FloatingTasksButton_Click" Grid.Column="1">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="23">
                        <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Botón flotante superior para minimizar la aplicacion-->
        <Button x:Name="FloatingHideButton"
        Width="26"
        Height="26"
        Content="X"
        FontSize="12"
        FontWeight="Bold"
        Foreground="White"
        Background="#DC2626"
        BorderBrush="#991B1B"
        BorderThickness="1"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="0,0,16,134"
        Cursor="Hand"
        ToolTip="Ocultar aplicación"
        Click="FloatingHideButton_Click" Grid.Column="1">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="13">
                        <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Avatar flotante principal -->
        <Border x:Name="AvatarBorder"
                Width="118"
                Height="118"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,16,16"
                Background="#FFFFFF"
                CornerRadius="64"
                BorderBrush="#22C55E"
                BorderThickness="3"
                ToolTip="Haz clic para consultar al Asistente "
                RenderTransformOrigin="0.5,0.5"
                MouseEnter="Avatar_MouseEnter"
                MouseLeave="Avatar_MouseLeave"
                MouseLeftButtonDown="Avatar_MouseLeftButtonDown" Grid.Column="1">

            <Border.RenderTransform>
                <ScaleTransform x:Name="AvatarScale"
                    ScaleX="1"
                    ScaleY="1"/>
            </Border.RenderTransform>

            <Border.Effect>
                <DropShadowEffect BlurRadius="22"
                                  ShadowDepth="5"
                                  Opacity="0.28"/>
            </Border.Effect>

            <Grid>
                <Ellipse x:Name="AvatarGlow"
                         Fill="#EFF6FF"
                         Margin="8"/>

                <Image Source="/Assets/avatar.png"
                       Stretch="Uniform"
                       Margin="0,-5,2,-5"/>
            </Grid>
        </Border>

    </Grid>
</Window>
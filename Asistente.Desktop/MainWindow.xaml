<Window x:Class="Asistente.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asistente "
        Icon="Assets/avatar.ico"
        Width="920"
        Height="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Window.Resources>

        <!-- Estilo base para botones principales -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para botones secundarios -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <!-- Estilo para botón de cancelar -->
        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#F97316"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Botón flotante secundario junto al avatar -->
        <Style x:Key="FloatingCircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="28">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                          ShadowDepth="4"
                                          Opacity="0.22"/>
                            </Border.Effect>

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Animación de apertura del panel de chat -->
        <Storyboard x:Key="OpenChatStoryboard">
            <DoubleAnimation Storyboard.TargetName="ChatPanel"
                     Storyboard.TargetProperty="Opacity"
                     From="0"
                     To="1"
                     Duration="0:0:0.18"/>

            <DoubleAnimation Storyboard.TargetName="ChatPanelScale"
                     Storyboard.TargetProperty="ScaleX"
                     From="0.92"
                     To="1"
                     Duration="0:0:0.18"/>

            <DoubleAnimation Storyboard.TargetName="ChatPanelScale"
                     Storyboard.TargetProperty="ScaleY"
                     From="0.92"
                     To="1"
                     Duration="0:0:0.18"/>
        </Storyboard>

        <!-- Animación de cierre del panel de chat -->
        <Storyboard x:Key="CloseChatStoryboard">
            <DoubleAnimation Storyboard.TargetName="ChatPanel"
                     Storyboard.TargetProperty="Opacity"
                     From="1"
                     To="0"
                     Duration="0:0:0.14"/>

            <DoubleAnimation Storyboard.TargetName="ChatPanelScale"
                     Storyboard.TargetProperty="ScaleX"
                     From="1"
                     To="0.92"
                     Duration="0:0:0.14"/>

            <DoubleAnimation Storyboard.TargetName="ChatPanelScale"
                     Storyboard.TargetProperty="ScaleY"
                     From="1"
                     To="0.92"
                     Duration="0:0:0.14"/>
        </Storyboard>

        <!-- Animación de apertura del panel de impresión rápida -->
        <Storyboard x:Key="OpenQuickPrintStoryboard">
            <DoubleAnimation Storyboard.TargetName="QuickPrintPanel"
                     Storyboard.TargetProperty="Opacity"
                     From="0"
                     To="1"
                     Duration="0:0:0.18"/>

            <DoubleAnimation Storyboard.TargetName="QuickPrintPanelScale"
                     Storyboard.TargetProperty="ScaleX"
                     From="0.92"
                     To="1"
                     Duration="0:0:0.18"/>

            <DoubleAnimation Storyboard.TargetName="QuickPrintPanelScale"
                     Storyboard.TargetProperty="ScaleY"
                     From="0.92"
                     To="1"
                     Duration="0:0:0.18"/>
        </Storyboard>

        <!-- Animación de cierre del panel de impresión rápida -->
        <Storyboard x:Key="CloseQuickPrintStoryboard">
            <DoubleAnimation Storyboard.TargetName="QuickPrintPanel"
                     Storyboard.TargetProperty="Opacity"
                     From="1"
                     To="0"
                     Duration="0:0:0.14"/>

            <DoubleAnimation Storyboard.TargetName="QuickPrintPanelScale"
                     Storyboard.TargetProperty="ScaleX"
                     From="1"
                     To="0.92"
                     Duration="0:0:0.14"/>

            <DoubleAnimation Storyboard.TargetName="QuickPrintPanelScale"
                     Storyboard.TargetProperty="ScaleY"
                     From="1"
                     To="0.92"
                     Duration="0:0:0.14"/>
        </Storyboard>

        <!-- Animación de apertura del panel de carteles -->
        <Storyboard x:Key="OpenPosterPanelStoryboard">
            <DoubleAnimation Storyboard.TargetName="PosterPanel"
                     Storyboard.TargetProperty="Opacity"
                     From="0"
                     To="1"
                     Duration="0:0:0.18"/>

            <DoubleAnimation Storyboard.TargetName="PosterPanelScale"
                     Storyboard.TargetProperty="ScaleX"
                     From="0.92"
                     To="1"
                     Duration="0:0:0.18"/>

            <DoubleAnimation Storyboard.TargetName="PosterPanelScale"
                     Storyboard.TargetProperty="ScaleY"
                     From="0.92"
                     To="1"
                     Duration="0:0:0.18"/>
        </Storyboard>

        <!-- Animación de cierre del panel de carteles -->
        <Storyboard x:Key="ClosePosterPanelStoryboard">
            <DoubleAnimation Storyboard.TargetName="PosterPanel"
                     Storyboard.TargetProperty="Opacity"
                     From="1"
                     To="0"
                     Duration="0:0:0.14"/>

            <DoubleAnimation Storyboard.TargetName="PosterPanelScale"
                     Storyboard.TargetProperty="ScaleX"
                     From="1"
                     To="0.92"
                     Duration="0:0:0.14"/>

            <DoubleAnimation Storyboard.TargetName="PosterPanelScale"
                     Storyboard.TargetProperty="ScaleY"
                     From="1"
                     To="0.92"
                     Duration="0:0:0.14"/>
        </Storyboard>

        <Style x:Key="PosterGreenHoverButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#16A34A"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#15803D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PosterPrintHoverButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#1E40AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="0,-60,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="237*"/>
            <ColumnDefinition Width="223*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel principal del chat -->
        <Border x:Name="ChatPanel"
                Width="440"
                Height="500"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="442,180,0,0"
                Background="#FAFFFFFF"
                CornerRadius="26"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                Padding="18"
                Opacity="0"
                RenderTransformOrigin="0.5,1"
                Visibility="Collapsed" Grid.ColumnSpan="2">

            <Border.RenderTransform>
                <ScaleTransform x:Name="ChatPanelScale"
                    ScaleX="0.92"
                    ScaleY="0.92"/>
            </Border.RenderTransform>

            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="6"
                                  Opacity="0.25"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Mini avatar en cabecera -->
                    <Border Grid.Column="0"
                            Width="42"
                            Height="42"
                            Background="#EFF6FF"
                            CornerRadius="21"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            Margin="0,0,10,0">
                        <Image Source="/Assets/avatar.png"
                               Stretch="Uniform"
                               Margin="5"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   Text="Asistente "
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>

                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <Ellipse x:Name="StatusIndicator"
                                     Width="8"
                                     Height="8"
                                     Fill="#22C55E"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"/>

                            <TextBlock x:Name="StatusText"
                                       Text="Listo para ayudarte."
                                       FontSize="12"
                                       Foreground="#6B7280"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="×"
                            Width="34"
                            Height="34"
                            Background="#F3F4F6"
                            Foreground="#111827"
                            BorderThickness="0"
                            FontSize="18"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="HideChat_Click"/>
                </Grid>

                <!-- Línea separadora -->
                <Border Grid.Row="1"
                        Height="1"
                        Background="#E5E7EB"
                        Margin="0,0,0,12"/>

                <!-- Zona de respuesta -->
                <Border Grid.Row="2"
                        Background="#F9FAFB"
                        CornerRadius="16"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Padding="12">

                    <ScrollViewer x:Name="ResponseScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent">
                        <TextBlock x:Name="ResponseText"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="#1F2937"
                                   LineHeight="22"/>
                    </ScrollViewer>
                </Border>

                <!-- Entrada de texto y botones -->
                <Grid Grid.Row="3" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FFFFFF"
                            CornerRadius="14"
                            BorderBrush="#D1D5DB"
                            BorderThickness="1"
                            Padding="0">
                        <TextBox x:Name="QuestionBox"
                                 Height="42"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#111827"
                                 KeyDown="QuestionBox_KeyDown"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Pulsa Enter para enviar"
                                   FontSize="11"
                                   Foreground="#9CA3AF"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">

                            <Button Content="Limpiar"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    Click="ClearButton_Click"/>

                            <Button x:Name="CancelButton"
                                    Content="Cancelar"
                                    Style="{StaticResource CancelButtonStyle}"
                                    Margin="0,0,8,0"
                                    IsEnabled="False"
                                    Click="CancelButton_Click"/>

                            <Button x:Name="SendButton"
                                    Content="Enviar"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SendButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- Panel desplegable de impresión rápida -->
        <Border x:Name="QuickPrintPanel"
        Width="390"
        Height="330"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="0,0,143,168"
        Background="#FAFFFFFF"
        CornerRadius="24"
        BorderBrush="#D1D5DB"
        BorderThickness="1"
        Padding="18"
        Opacity="0"
        RenderTransformOrigin="0.85,1"
        Visibility="Collapsed" Grid.ColumnSpan="2">

            <Border.RenderTransform>
                <ScaleTransform x:Name="QuickPrintPanelScale"
                        ScaleX="0.92"
                        ScaleY="0.92"/>
            </Border.RenderTransform>

            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                          ShadowDepth="6"
                          Opacity="0.25"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Impresión rápida"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#111827"/>

                        <TextBlock Text="PDF, imágenes y documentos compatibles"
                           FontSize="12"
                           Foreground="#6B7280"
                           Margin="0,3,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                    Content="×"
                    Width="34"
                    Height="34"
                    Background="#F3F4F6"
                    Foreground="#111827"
                    BorderThickness="0"
                    FontSize="18"
                    FontWeight="Bold"
                    Cursor=""
                    Click="HideQuickPrintPanel_Click"/>
                </Grid>

                <!-- Línea separadora -->
                <Border Grid.Row="1"
                Height="1"
                Background="#E5E7EB"
                Margin="0,0,0,14"/>

                <!-- Drop Zone -->
                <Border x:Name="QuickPrintDropZone"
                Grid.Row="2"
                Background="#F9FAFB"
                BorderBrush="#CBD5E1"
                BorderThickness="2"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,0,14"
                AllowDrop="True"
                DragEnter="QuickPrintDropZone_DragEnter"
                DragOver="QuickPrintDropZone_DragOver"
                DragLeave="QuickPrintDropZone_DragLeave"
                Drop="QuickPrintDropZone_Drop">

                    <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <TextBlock Text="⬇"
                           FontSize="28"
                           Foreground="#2563EB"
                           HorizontalAlignment="Center"/>

                        <TextBlock Text="Arrastra aquí tus archivos"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>

                        <TextBlock Text="En la siguiente fase activaremos la carga del archivo"
                           FontSize="11"
                           Foreground="#6B7280"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Archivo seleccionado -->
                <TextBlock x:Name="QuickPrintSelectedFileText"
                   Grid.Row="3"
                   Text="Ningún archivo seleccionado."
                   FontSize="12"
                   Foreground="#6B7280"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,12"/>

                <!-- Acciones inferiores -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="QuickPrintPrinterComboBox"
                              Grid.Column="0"
                              Height="36"
                              Margin="0,0,10,0"
                              VerticalContentAlignment="Center"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="PrinterName"
                              SelectionChanged="QuickPrintPrinterComboBox_SelectionChanged"
                              IsEnabled="False"
                              ToolTip="Selecciona la impresora de destino"/>

                    <Button x:Name="QuickPrintPrintButton"
                            Grid.Column="1"
                            Content="Imprimir"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsEnabled="False"
                            Click="QuickPrintPrintButton_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Panel desplegable de generación de carteles -->
        <Border x:Name="PosterPanel"
                Width="720"
                Height="740"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,198,147"
                Background="#FAFFFFFF"
                CornerRadius="24"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                Padding="0"
                SnapsToDevicePixels="True"
                ClipToBounds="False"
                Opacity="0"
                RenderTransformOrigin="0.85,1"
                Visibility="Collapsed" Grid.ColumnSpan="2">

            <Border.RenderTransform>
                <ScaleTransform x:Name="PosterPanelScale"
                                ScaleX="0.92"
                                ScaleY="0.92"/>
            </Border.RenderTransform>

            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="6"
                                  Opacity="0.25"/>
            </Border.Effect>

            <Grid Margin="18,16,18,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Generador de carteles"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>

                        <TextBlock Text="Busca productos, añádelos al lote y genera carteles"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="×"
                            Width="34"
                            Height="34"
                            Background="#F3F4F6"
                            Foreground="#111827"
                            BorderThickness="0"
                            FontSize="18"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="HidePosterPanel_Click"/>
                </Grid>

                <!-- Separador -->
                <Border Grid.Row="1"
                        Height="1"
                        Background="#E5E7EB"
                        Margin="0,0,0,14"/>



                <!-- Formulario con scroll para evitar recortes -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True"
                              Margin="0,0,0,0"
                              Padding="0,0,10,0">

                    <!-- Formulario -->
                    <Grid Margin="0,0,4,0"
                          Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="185"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="140"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Selector de modo: Cartel / Etiqueta -->
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Tipo:"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#374151"
                                   Margin="0,0,10,10"/>

                        <ComboBox x:Name="PosterTypeComboBox"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  Height="34"
                                  Margin="0,0,0,10"
                                  SelectedIndex="0"
                                  SelectionChanged="PosterTypeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Cartel"/>
                            <ComboBoxItem Content="Etiqueta"/>
                        </ComboBox>

                        <Grid x:Name="PosterModeContentGrid"
                              Grid.Row="1"
                              Grid.RowSpan="6"
                              Grid.ColumnSpan="2">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="185"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="140"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="125"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- contenido actual de carteles -->
                            <!-- Tamaño -->
                            <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="Tamaño:"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#374151"
                                   Margin="0,0,10,10"/>

                            <ComboBox x:Name="PosterSizeComboBox"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Height="34"
                                  Margin="0,0,0,10"
                                  SelectedIndex="1">
                                <ComboBoxItem Content="A3"/>
                                <ComboBoxItem Content="A4"/>
                                <ComboBoxItem Content="A5"/>
                                <ComboBoxItem Content="A6"/>
                            </ComboBox>

                            <!-- Tipo de oferta -->
                            <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="Oferta:"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#374151"
                                   Margin="0,0,10,10"/>

                            <ComboBox x:Name="PosterPriceTypeComboBox"
                                  Grid.Row="2"
                                  Grid.Column="1"
                                  Height="34"
                                  Margin="0,0,0,10"
                                  SelectedIndex="0">
                                <ComboBoxItem Content="Normal"/>
                                <ComboBoxItem Content="Novedad"/>
                                <ComboBoxItem Content="Super Oferta"/>
                                <ComboBoxItem Content="Oferta 1+1"/>
                                <ComboBoxItem Content="Oferta 2+1"/>
                                <ComboBoxItem Content="Oferta 3+1"/>
                                <ComboBoxItem Content="Oferta 4+1"/>
                                <ComboBoxItem Content="Oferta 5+1"/>
                            </ComboBox>

                            <!-- Bloque de búsqueda -->
                            <Border Grid.Row="3"
                                Grid.ColumnSpan="2"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12"
                                Margin="0,0,0,10">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                           Text="Buscar producto"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           Margin="0,0,0,8"/>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox x:Name="PosterSearchTypeComboBox"
                                              Grid.Column="0"
                                              Height="34"
                                              Margin="0,0,8,0"
                                              SelectedIndex="0"
                                              SelectionChanged="PosterSearchTypeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="EAN"/>
                                            <ComboBoxItem Content="Código artículo"/>
                                            <ComboBoxItem Content="Nombre"/>
                                        </ComboBox>

                                        <TextBox x:Name="PosterSearchTextBox"
                                             Grid.Column="1"
                                             Height="34"
                                             VerticalContentAlignment="Center"
                                             FontSize="14"
                                             ToolTip="Introduce EAN, código de artículo o fragmento de nombre"
                                             KeyDown="PosterSearchTextBox_KeyDown"/>

                                        <Button x:Name="PosterSearchButton"
                                            Grid.Column="2"
                                            Content="Buscar"
                                            Style="{StaticResource PosterGreenHoverButtonStyle}"
                                            Margin="8,0,0,0"
                                            Click="PosterSearchButton_Click"/>
                                    </Grid>


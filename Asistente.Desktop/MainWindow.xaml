                                    CornerRadius="14"
                                    Padding="12"
                                    Margin="0,0,0,10">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Etiquetas disponibles"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Margin="0,0,0,8"/>

                                    <ListBox x:Name="LabelPendingListBox"
                                             Grid.Row="1"
                                             DisplayMemberPath="DisplayText"
                                             SelectionMode="Extended"
                                             HorizontalContentAlignment="Stretch"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>

                            <!-- Botón añadir etiquetas -->
                            <Grid Grid.Row="3"
                                  Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Selecciona una o varias etiquetas y añádelas al lote."
                                           FontSize="12"
                                           Foreground="#6B7280"
                                           VerticalAlignment="Center"/>

                                <Button x:Name="LabelAddSelectedButton"
                                        Grid.Column="1"
                                        Content="Añadir"
                                        Style="{StaticResource PosterGreenHoverButtonStyle}"
                                        Click="LabelAddSelectedButton_Click"/>
                            </Grid>

                            <!-- Lista de etiquetas seleccionadas -->
                            <Border Grid.Row="4"
                                    Background="#F9FAFB"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12"
                                    Margin="0,0,0,10">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Etiquetas seleccionadas"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               Margin="0,0,0,8"/>

                                    <ListBox x:Name="LabelSelectedListBox"
                                             Grid.Row="1"
                                             DisplayMemberPath="DisplayText"
                                             SelectionMode="Extended"
                                             HorizontalContentAlignment="Stretch"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>

                            <!-- Botones quitar -->
                            <Grid Grid.Row="5"
                                  Margin="0,0,0,10">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="LabelSelectedCountText"
                                           Grid.Column="0"
                                           Text="Etiquetas seleccionadas: 0"
                                           FontSize="12"
                                           Foreground="#6B7280"
                                           VerticalAlignment="Center"/>

                                <Button x:Name="LabelRemoveSelectedButton"
                                        Grid.Column="1"
                                        Content="Quitar"
                                        Style="{StaticResource PosterGreenHoverButtonStyle}"
                                        Margin="0,0,8,0"
                                        Click="LabelRemoveSelectedButton_Click"/>

                                <Button x:Name="LabelClearSelectedButton"
                                        Grid.Column="2"
                                        Content="Quitar todo"
                                        Style="{StaticResource PosterGreenHoverButtonStyle}"
                                        Click="LabelClearSelectedButton_Click"/>
                            </Grid>

                            <!-- Fase futura: marcar como impresas -->
                            <CheckBox x:Name="LabelMarkAsPrintedCheckBox"
                                      Grid.Row="6"
                                      Content="Marcar como impresas después de imprimir"
                                      FontSize="12"
                                      Foreground="#6B7280"
                                      IsEnabled="True"
                                      ToolTip="Pendiente de implementar cuando confirmemos la consulta UPDATE."
                                      Margin="0,0,0,8"/>
                        </Grid>
                        <!-- Impresora -->
                        <TextBlock Grid.Row="7"
                               Grid.Column="0"
                               Text="Impresora:"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="#374151"
                               Margin="0,0,10,10"/>

                        <ComboBox x:Name="PosterPrinterComboBox"
                              Grid.Row="7"
                              Grid.Column="1"
                              Height="34"
                              Margin="0,0,0,10"
                              VerticalContentAlignment="Center"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="PrinterName"
                              IsEnabled="False"
                              ToolTip="Selecciona la impresora para el cartel"/>

                        <!-- Estado -->
                        <Border Grid.Row="8"
                            Grid.ColumnSpan="2"
                            Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12"
                            Margin="0,4,0,0">

                            <TextBlock x:Name="PosterStatusText"
                                   Text="Busca productos y añádelos al listado para generar carteles."
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"/>
                        </Border>
                    </Grid>

                </ScrollViewer>

                <!-- Botones -->
                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="PosterGenerateButton"
                            Grid.Column="1"
                            Content="Generar PDF"
                            Style="{StaticResource PosterGreenHoverButtonStyle}"
                            Margin="0,0,10,0"
                            Click="PosterGenerateButton_Click"/>

                    <Button x:Name="PosterPreviewButton"
                            Grid.Column="2"
                            Content="Previsualizar"
                            Style="{StaticResource PosterGreenHoverButtonStyle}"
                            IsEnabled="False"
                            Margin="10,0,10,0"
                            Click="PosterPreviewButton_Click"/>

                    <Button x:Name="PosterPrintButton"
                            Grid.Column="3"
                            Content="Imprimir"
                            Style="{StaticResource PosterPrintHoverButtonStyle}"
                            IsEnabled="False"
                            Click="PosterPrintButton_Click"/>
                </Grid>
            </Grid>
        </Border>


        <!-- Panel de tareas y recordatorios -->
        <Border x:Name="TasksPanel"
                Width="720"
                Height="850"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,185,95"
                Background="#FAFFFFFF"
                CornerRadius="24"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                Padding="0"
                SnapsToDevicePixels="True"
                Visibility="Collapsed"
                Opacity="0"
                RenderTransformOrigin="0.85,1" Grid.ColumnSpan="2">

            <Border.RenderTransform>
                <ScaleTransform x:Name="TasksPanelScale"
                                ScaleX="0.92"
                                ScaleY="0.92"/>
            </Border.RenderTransform>

            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="6"
                                  Opacity="0.25"/>
            </Border.Effect>

            <Grid Margin="18,16,18,14">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="390"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <Grid Grid.Row="0"
                      Margin="0,0,0,12">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tareas y recordatorios"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>

                        <TextBlock Text="Gestión centralizada de tareas para todos los usuarios"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <Button x:Name="TasksRefreshButton"
                            Grid.Column="1"
                            Content="Actualizar"
                            Style="{StaticResource PosterGreenHoverButtonStyle}"
                            Click="TasksRefreshButton_Click"/>
                </Grid>

                <!-- Mitad superior: nueva tarea -->
                <Border Grid.Row="1"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Margin="0,0,0,12">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Nueva tarea / recordatorio"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,0,0,10"/>

                        <Grid Grid.Row="1"
                              Margin="0,0,0,8">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Escrito por:"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#374151"/>

                            <TextBox x:Name="TaskWrittenByTextBox"
                                     Grid.Column="1"
                                     Height="32"
                                     Margin="0,0,12,0"
                                     VerticalContentAlignment="Center"/>

                            <TextBlock Grid.Column="2"
                                       Text="Dirigido a:"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#374151"/>

                            <TextBox x:Name="TaskAssignedToTextBox"
                                     Grid.Column="3"
                                     Height="32"
                                     VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="2"
                              Margin="0,0,0,8">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Emisión:"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#374151"/>

                            <TextBox x:Name="TaskCreatedAtTextBox"
                                     Grid.Column="1"
                                     Height="32"
                                     Margin="0,0,12,0"
                                     IsReadOnly="True"
                                     Background="#EEF2FF"
                                     VerticalContentAlignment="Center"/>

                            <TextBlock Grid.Column="2"
                                       Text="Vencimiento:"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#374151"/>

                            <DatePicker x:Name="TaskDueDatePicker"
                                        Grid.Column="3"
                                        Height="32"/>
                        </Grid>

                        <Grid Grid.Row="3"
                              Margin="0,0,0,8">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Grupo:"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#374151"/>

                            <ComboBox x:Name="TaskGroupComboBox"
                                      Grid.Column="1"
                                      Height="32"
                                      Margin="0,0,12,0"
                                      VerticalContentAlignment="Center"/>

                            <TextBlock Grid.Column="2"
                                       Text="Urgencia:"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#374151"/>

                            <ComboBox x:Name="TaskPriorityComboBox"
                                      Grid.Column="3"
                                      Height="32"
                                      SelectedIndex="0"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Normal"/>
                                <ComboBoxItem Content="Urgente"/>
                                <ComboBoxItem Content="Muy urgente"/>
                            </ComboBox>
                        </Grid>

                        <Grid Grid.Row="4"
                              Margin="0,0,0,10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Descripción:"
                                       VerticalAlignment="Top"
                                       FontSize="12"
                                       Foreground="#374151"
                                       Margin="0,4,0,0"/>
                            <TextBox x:Name="TaskDescriptionTextBox"
                                     Grid.Column="1"
                                     MinHeight="80"
                                     Height="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"/>
                        </Grid>

                        <Grid Grid.Row="5"
                              Margin="0,0,0,8">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Adjuntos:"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#374151"/>

                            <TextBlock x:Name="TaskNewAttachmentsText"
